<?xml version="1.0" encoding="utf-8"?>
<!-- Satisfies checklist 2.1: styles defined -->
<resources>

    <!-- Base styles (required by dot-chain naming convention) -->
    <style name="Style" />
    <style name="Style.FreshGuide" />
    <style name="Style.FreshGuide.Text" />

    <!-- Card styles -->
    <style name="Style.FreshGuide.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface_white</item>
    </style>

    <style name="Style.FreshGuide.Card.Action" parent="Style.FreshGuide.Card">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">3dp</item>
    </style>

    <!-- Button styles -->
    <style name="Style.FreshGuide.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/green_primary</item>
        <item name="android:textColor">@color/surface_white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Style.FreshGuide.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/green_primary</item>
        <item name="android:textColor">@color/green_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Style.FreshGuide.Button.Danger" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/orange_accent</item>
        <item name="android:textColor">@color/surface_white</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Text styles -->
    <style name="Style.FreshGuide.Text.Header">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Style.FreshGuide.Text.SectionLabel">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="Style.FreshGuide.Text.Badge" parent="">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/surface_white</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:background">@drawable/bg_chip_green</item>
    </style>

    <!-- Input styles -->
    <style name="Style.FreshGuide.Input">
        <item name="android:background">@drawable/bg_search_bar</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <style name="CustomTimePickerDialog" parent="@style/Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_time_picker_dialog</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:timePickerStyle">@style/CustomTimePickerStyle</item>
        <item name="colorAccent">@color/green_primary</item>
        <item name="android:textColorPrimary">@color/green_primary</item>
        <item name="android:textColorSecondary">@color/green_primary</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
    </style>

    <style name="CustomTimePickerStyle" parent="@android:style/Widget.Material.TimePicker">
        <item name="android:textColorPrimary">@color/green_primary</item>
        <item name="android:textColorSecondary">@color/green_primary</item>
    </style>

    <style name="CustomBottomSheetDialog" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="CustomNumberPickerTheme" parent="Theme.AppCompat.Light">
        <item name="android:textColorPrimary">@color/green_primary</item>
        <item name="android:textColorSecondary">@color/green_primary</item>
    </style>




</resources>
