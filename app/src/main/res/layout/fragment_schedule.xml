<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_bg"
    android:orientation="vertical"
    android:paddingTop="18dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_schedule_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/instrument_bold"
                android:text="Class Schedule"
                android:textColor="@color/green_primary"
                android:textSize="40sp" />

            <TextView
                android:id="@+id/tv_schedule_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/instrument_regular"
                android:textColor="@color/text_hint"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_add_schedule"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="+"
            android:textColor="@color/green_primary"
            android:textSize="34sp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_today_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:visibility="gone"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/border_default"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tv_summary_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOU HAVE CLASS SCHEDULE TODAY"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_summary_course_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_summary_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#D63467"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_summary_professor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_summary_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Schedule view"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_schedule_view_toggle_container"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp">

            <TextView
                android:id="@+id/btn_view_weekly"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/bg_schedule_view_toggle_selected"
                android:gravity="center"
                android:minWidth="66dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="Weekly"
                android:textColor="@color/surface_white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_view_daily"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/bg_schedule_view_toggle_plain"
                android:gravity="center"
                android:minWidth="66dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="Daily"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/daily_day_selector_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <TextView
                android:id="@+id/daily_day_mon"
                android:layout_width="46dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="Mon"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/daily_day_tue"
                android:layout_width="46dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="Tue"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/daily_day_wed"
                android:layout_width="46dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="Wed"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/daily_day_thu"
                android:layout_width="46dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="Thu"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/daily_day_fri"
                android:layout_width="46dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="Fri"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/daily_day_sat"
                android:layout_width="46dp"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="Sat"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="8dp">

        <ScrollView
            android:id="@+id/scroll_weekly_schedule"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="vertical"
            android:visibility="gone">

            <com.example.freshguide.ui.view.WeeklyScheduleGridView
                android:id="@+id/weekly_schedule_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </ScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_daily_schedule"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="10dp"
            android:scrollbars="vertical"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_my_schedule"
                android:tint="@color/text_hint" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="No schedule found."
                android:textColor="@color/text_hint"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btn_empty_add_schedule"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_schedule_add_outline"
                android:drawableStart="@drawable/ic_nav_schedule"
                android:drawablePadding="6dp"
                android:paddingStart="18dp"
                android:paddingTop="8dp"
                android:paddingEnd="18dp"
                android:paddingBottom="8dp"
                android:text="Schedule"
                android:textColor="@color/green_primary"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
