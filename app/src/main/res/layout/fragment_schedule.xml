<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_default"
    android:orientation="vertical"
    android:paddingStart="@dimen/screen_horizontal_gutter"
    android:paddingEnd="@dimen/screen_horizontal_gutter"
    android:paddingBottom="8dp">

    <!-- ── Header ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="24dp"
        android:paddingBottom="17dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_schedule_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/playfair_bold"
                android:text="Class Schedule"
                android:textColor="@color/green_primary"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:textSize="37sp" />

            <TextView
                android:id="@+id/tv_schedule_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/inter_bold"
                android:textColor="@color/text_hint"
                android:textSize="15sp"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_add_schedule"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="4dp"
            android:contentDescription="Add schedule"
            android:src="@drawable/ic_schedule_add"
            android:tint="@color/green_primary" />
    </LinearLayout>

    <!-- ── Summary Card ── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_today_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="@color/background_subtle"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/border_default"
        app:strokeWidth="1dp">

        <LinearLayout
            android:id="@+id/layout_summary_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="16dp"
            android:paddingEnd="28dp"
            android:paddingBottom="18dp">

            <TextView
                android:id="@+id/tv_summary_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:fontFamily="@font/inter_medium"
                android:includeFontPadding="false"
                android:text="YOU HAVE NO CLASS SCHEDULE"
                android:textAllCaps="true"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:layout_marginBottom="10dp"
                android:letterSpacing="0.06" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/img_summary_logo"
                    android:layout_width="100dp"
                    android:layout_height="80dp"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ucc_logo" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_summary_subject_code"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_medium"
                        android:includeFontPadding="false"
                        android:text="CCS 103"
                        android:textAllCaps="true"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.03"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tv_summary_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/inter_bold"
                        android:includeFontPadding="false"
                        android:text="FREE TIME"
                        android:textAllCaps="true"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:maxLines="2"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tv_summary_professor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/inter_medium"
                        android:includeFontPadding="false"
                        android:text="PROF. JACK ROBERTO"
                        android:textAllCaps="true"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.03"
                        android:maxLines="2"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tv_summary_location"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter_medium"
                        android:includeFontPadding="false"
                        android:text="COMPUTER LAB"
                        android:textAllCaps="true"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.03"
                        android:maxLines="2"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_summary_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="23dp"
                android:fontFamily="@font/inter_medium"
                android:includeFontPadding="false"
                android:text="YOUR NEXT SCHEDULE WILL APPEAR HERE."
                android:textAllCaps="true"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:letterSpacing="0.04" />

            <TextView
                android:id="@+id/tv_summary_course_code"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ── Day selector stub (36dp gutter only; labels are drawn in Java) ── -->
    <!--
        The actual Mon–Sat labels are now rendered inside the same
        HorizontalScrollView as the grid (see buildTimeline in Java),
        so header and grid always scroll in lockstep.
        This container only anchors the gutter spacer and the host view
        that Java will populate.
    -->
    <LinearLayout
        android:id="@+id/daily_day_selector_container"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="2dp"
        android:orientation="horizontal">

        <!-- 36dp gutter matches LABEL_WIDTH_DP in Java -->
        <View
            android:layout_width="36dp"
            android:layout_height="match_parent" />

        <!-- Java will call buildDayHeaderRow() and add it here at runtime -->
        <FrameLayout
            android:id="@+id/day_header_host"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- ── Content area ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/timeline_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:fillViewport="false"
            android:overScrollMode="never"
            android:visibility="gone">

            <FrameLayout
                android:id="@+id/timeline_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:paddingBottom="32dp" />
        </ScrollView>

        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/ic_my_schedule" />

            <TextView
                android:id="@+id/tv_empty_state_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="No schedule found."
                android:textColor="@color/text_hint"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btn_empty_add_schedule"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_schedule_add_outline"
                android:drawableStart="@drawable/ic_schedule_add"
                android:drawableTint="@color/green_primary"
                android:drawablePadding="6dp"
                android:gravity="center_vertical"
                android:paddingStart="25dp"
                android:paddingTop="6dp"
                android:paddingEnd="25dp"
                android:paddingBottom="6dp"
                android:text="Schedule"
                android:textColor="@color/green_primary"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
