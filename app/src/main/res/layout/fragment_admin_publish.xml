<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_default"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_horizontal_gutter"
        android:paddingTop="20dp"
        android:paddingEnd="@dimen/screen_horizontal_gutter"
        android:paddingBottom="40dp">

        <TextView
            style="@style/Style.FreshGuide.Text.PageTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/admin_publish_title" />

        <TextView
            style="@style/Style.FreshGuide.Text.PageSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/admin_publish_subtitle" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Style.FreshGuide.Card.Highlight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="20dp"
                android:paddingEnd="22dp"
                android:paddingBottom="20dp">

                <TextView
                    style="@style/Style.FreshGuide.Text.CardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_section_release" />

                <TextView
                    style="@style/Style.FreshGuide.Text.CardBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="This publish flow keeps student devices in sync with your latest verified local data." />

                <TextView
                    android:id="@+id/tv_publish_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_schedule_add_outline"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="10dp"
                    android:textColor="@color/green_primary"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Style.FreshGuide.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp"
                android:paddingBottom="18dp">

                <TextView
                    style="@style/Style.FreshGuide.Text.FieldLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_status_published" />

                <TextView
                    style="@style/Style.FreshGuide.Text.CardBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Publishing increments the sync version and makes new campus content available on the next student refresh." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btn_publish"
            style="@style/Style.FreshGuide.Button.Admin.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:text="Publish Now"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
