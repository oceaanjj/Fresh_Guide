<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_default"
    android:clipToPadding="false"
    android:clipChildren="false"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/main_content_wrapper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false">

        <!-- Header bar for back navigation -->
        <LinearLayout
            android:id="@+id/header_bar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:paddingStart="@dimen/screen_horizontal_gutter"
            android:paddingEnd="@dimen/screen_horizontal_gutter"
            android:gravity="center_vertical"
            android:background="@color/background_default"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/header_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_back"
                app:tint="@color/green_primary" />

            <TextView
                android:id="@+id/header_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:fontFamily="@font/inter_bold"
                android:textSize="17sp"
                android:textColor="@color/green_primary"
                android:text="@string/app_name" />
        </LinearLayout>

        <!-- Fragment container — NavHostFragment fills this area -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/nav_host_fragment"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:defaultNavHost="true"
            app:navGraph="@navigation/nav_graph" />
    </LinearLayout>

    <!-- Bottom Navigation (custom) -->
    <FrameLayout
        android:id="@+id/nav_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/transparent"
        android:paddingStart="@dimen/screen_horizontal_gutter"
        android:paddingEnd="@dimen/screen_horizontal_gutter"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:elevation="8dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/nav_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/background_card"
            app:cardElevation="0dp"
            app:strokeColor="@color/border_subtle"
            app:strokeWidth="1dp"
            app:cardCornerRadius="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <LinearLayout
                    android:id="@+id/nav_item_home"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp">

                    <ImageView
                        android:id="@+id/nav_icon_home"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@string/nav_home"
                        android:src="@drawable/ic_nav_home"
                        app:tint="@color/text_hint" />

                    <TextView
                        android:id="@+id/nav_text_home"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginEnd="4dp"
                        android:fontFamily="@font/instrument_regular"
                        android:text="@string/nav_home"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/nav_item_schedule"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp">

                    <ImageView
                        android:id="@+id/nav_icon_schedule"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@string/nav_schedule"
                        android:src="@drawable/ic_nav_schedule"
                        app:tint="@color/text_hint" />

                    <TextView
                        android:id="@+id/nav_text_schedule"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/instrument_regular"
                        android:text="@string/nav_schedule"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/nav_item_settings"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp">

                    <ImageView
                        android:id="@+id/nav_icon_settings"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@string/nav_settings"
                        android:src="@drawable/ic_nav_settings"
                        app:tint="@color/text_hint" />

                    <TextView
                        android:id="@+id/nav_text_settings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/instrument_regular"
                        android:text="@string/nav_settings"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/nav_item_profile"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp">

                    <ImageView
                        android:id="@+id/nav_icon_profile"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@string/nav_profile"
                        android:src="@drawable/ic_nav_profile"
                        app:tint="@color/text_hint" />

                    <TextView
                        android:id="@+id/nav_text_profile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/instrument_regular"
                        android:text="@string/nav_profile"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

</FrameLayout>
