<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/time_picker_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="30dp"
    android:paddingTop="18dp"
    android:paddingEnd="30dp"
    android:paddingBottom="22dp"
    android:layout_marginLeft="10dp"
    android:layout_marginRight="10dp"
    android:background="@drawable/bg_time_picker_modal">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_time_picker_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/inter_medium"
            android:text="Select a Time"
            android:layout_marginLeft="10dp"
            android:textColor="@color/green_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_time_confirm"
            android:layout_width="90dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_time_picker_confirm"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:text="Confirm"
            android:textColor="@color/time_picker_confirm_text"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:alpha="0.55"
        android:background="@color/green_primary" />

    <!-- Wheels row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Hour wheel -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_hour"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingBottom="88dp"
                android:paddingTop="88dp"
                android:scrollbars="none" />

            <View
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_gravity="top"
                android:background="@drawable/bg_wheel_fade_top"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no" />

            <View
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_wheel_fade_bottom"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no" />
        </FrameLayout>

        <!-- Colon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:fontFamily="@font/inter_medium"
            android:text=":"
            android:textColor="@color/time_picker_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <!-- Minute wheel -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_minute"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingBottom="88dp"
                android:paddingTop="88dp"
                android:scrollbars="none" />

            <View
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_gravity="top"
                android:background="@drawable/bg_wheel_fade_top"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no" />

            <View
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_wheel_fade_bottom"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no" />
        </FrameLayout>

        <!-- AM / PM chips — marginBottom centres the pair vertically
             within the 220dp wheel area -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/btn_am"
                android:layout_width="52dp"
                android:layout_height="40dp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center"
                android:text="AM"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_pm"
                android:layout_width="52dp"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center"
                android:text="PM"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>