<?xml version="1.0" encoding="utf-8"?>

    <FrameLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_default">

        <!--
            Pattern layer:
            A full-screen ImageView that tiles pattern_bg.png (your transparent PNG)
            over the background_default color. Alpha is set in code via LoginActivity
            depending on night mode: 0.12f (light) or 0.07f (dark).
            See: LoginActivity.applyPatternAlpha()
        -->
        <View
            android:id="@+id/iv_pattern"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_login_pattern" />

        <!-- Scrollable content so keyboard doesn't crush the card -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:overScrollMode="never">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/screen_min_height">

                <!--
                    Glass card: max 360dp, sits slightly above vertical center.
                    Background = bg_login_card.xml (semi-transparent + border)
                    Blur effect applied in code (API 31+) on the card view itself.
                -->
                <LinearLayout
                    android:id="@+id/loginCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="28dp"
                    android:paddingEnd="28dp"
                    android:paddingTop="44dp"
                    android:paddingBottom="44dp"
                    android:background="@drawable/bg_login_card"
                    app:layout_constraintWidth_max="360dp"
                    app:layout_constraintWidth_default="spread"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintVertical_bias="0.44"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp">

                    <!-- Logo photo -->
                    <ImageView
                        android:id="@+id/loginLogo"
                        android:layout_width="@dimen/login_logo_width"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:src="@drawable/logo"
                        android:contentDescription="@string/logo_description"
                        android:scaleType="fitCenter"
                        android:adjustViewBounds="true"
                        android:layout_marginBottom="32dp" />

                    <!-- Login mode hint -->

                    <!-- ── ADMIN MODE FIELDS (hidden by default) ── -->

                    <!-- Email label -->
                    <TextView
                        android:id="@+id/labelUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_username"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="6dp"
                        android:visibility="gone" />

                    <!-- Email input -->
                    <EditText
                        android:id="@+id/inputUsername"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="@string/hint_admin_email"
                        android:textColorHint="@color/text_hint"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:inputType="textEmailAddress"
                        android:singleLine="true"
                        android:layout_marginBottom="14dp"
                        android:visibility="gone" />

                    <!-- Password label -->
                    <TextView
                        android:id="@+id/labelPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_password"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="6dp"
                        android:visibility="gone" />

                    <!-- Password row -->
                    <FrameLayout
                        android:id="@+id/passwordRow"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="24dp"
                        android:visibility="gone">

                        <EditText
                            android:id="@+id/inputPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="@string/hint_password"
                            android:textColorHint="@color/text_hint"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:background="@drawable/bg_input_field"
                            android:paddingStart="14dp"
                            android:paddingEnd="50dp"
                            android:inputType="textPassword"
                            android:singleLine="true" />

                        <ImageButton
                            android:id="@+id/btnTogglePassword"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="end|center_vertical"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_eye_off"
                            android:background="@drawable/bg_ripple_circle"
                            android:tint="@color/text_hint"
                            android:contentDescription="@string/toggle_password_visibility" />

                    </FrameLayout>

                    <!-- ── LOADING ── -->
                    <ProgressBar
                        android:id="@+id/progress_bar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="12dp"
                        android:indeterminateTint="@color/green_primary"
                        android:visibility="gone" />

                    <!-- ── STUDENT MANUAL MODE FIELDS (hidden by default) ── -->

                    <!-- Student ID label -->
                    <TextView
                        android:id="@+id/labelStudentId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_student_id"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="6dp"
                        android:visibility="gone" />

                    <!-- Student ID input -->
                    <EditText
                        android:id="@+id/inputStudentId"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="@string/hint_student_id_manual"
                        android:textColorHint="@color/text_hint"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:inputType="text"
                        android:singleLine="true"
                        android:layout_marginBottom="24dp"
                        android:visibility="gone" />

                    <!-- ── PRIMARY BUTTON: Scan QR / Sign In ── -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnSignIn"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:text="@string/btn_scan_qr_login"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_extrabold"
                        android:background="@drawable/bg_btn_primary"
                        android:backgroundTint="@null"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginBottom="12dp" />

                    <!-- Debug-only manual input -->

                    <!-- ── SECONDARY BUTTON: Login as Admin / Back to QR ── -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnCreateAccount"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"

                        android:text="@string/btn_switch_to_admin_login"
                        android:textColor="@color/green_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_medium"

                        android:background="@drawable/bg_btn_secondary"
                        android:backgroundTint="@null"

                        android:insetTop="0dp"
                        android:insetBottom="0dp" />

    <!--                <TextView-->
    <!--                    android:id="@+id/tv_login_hint"-->
    <!--                    android:layout_width="match_parent"-->
    <!--                    android:layout_height="wrap_content"-->
    <!--                    android:layout_marginBottom="4dp"-->
    <!--                    android:layout_marginTop="10dp"-->
    <!--                    android:gravity="center"-->

    <!--                    android:text="@string/login_hint_qr_mode"-->
    <!--                    android:textSize="13sp"-->
    <!--                    android:textColor= "@color/label"-->
    <!--                    android:lineSpacingMultiplier="1.4" />-->

                    <TextView
                        android:id="@+id/btnManualStudentInput"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="10dp"
                        android:text="@string/manual_login"
                        android:textSize="13sp"
                        android:textColor="@color/green_primary"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </ScrollView>

    </FrameLayout>