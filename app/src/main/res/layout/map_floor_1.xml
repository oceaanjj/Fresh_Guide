<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_default">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="7dp">

        <View
            android:id="@+id/legend_classroom_dot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/bg_circle_classroom"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/legend_classroom_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Classroom"
            android:textColor="@color/floor_room_label"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/legend_classroom_dot"
            app:layout_constraintStart_toEndOf="@id/legend_classroom_dot"
            app:layout_constraintTop_toTopOf="@id/legend_classroom_dot" />

        <View
            android:id="@+id/legend_door_dot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginStart="28dp"
            android:background="@drawable/bg_circle_door"
            app:layout_constraintBottom_toBottomOf="@id/legend_classroom_dot"
            app:layout_constraintStart_toEndOf="@id/legend_classroom_text"
            app:layout_constraintTop_toTopOf="@id/legend_classroom_dot" />

        <TextView
            android:id="@+id/legend_door_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Door / Entrance"
            android:textColor="@color/floor_room_label"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/legend_door_dot"
            app:layout_constraintStart_toEndOf="@id/legend_door_dot"
            app:layout_constraintTop_toTopOf="@id/legend_door_dot" />

        <View
            android:id="@+id/legend_faculty_dot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginStart="28dp"
            android:background="@drawable/bg_circle_faculty"
            app:layout_constraintBottom_toBottomOf="@id/legend_classroom_dot"
            app:layout_constraintStart_toEndOf="@id/legend_door_text"
            app:layout_constraintTop_toTopOf="@id/legend_classroom_dot" />

        <TextView
            android:id="@+id/legend_faculty_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Faculty"
            android:textColor="@color/floor_room_label"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/legend_faculty_dot"
            app:layout_constraintStart_toEndOf="@id/legend_faculty_dot"
            app:layout_constraintTop_toTopOf="@id/legend_faculty_dot" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none"
        android:background="@color/background_default">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="14dp"
            android:background="@color/background_default"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:minHeight="1280dp"
            android:paddingBottom="24dp">

            <ImageView
                android:id="@+id/stairs_top"
                android:layout_width="94dp"
                android:layout_height="34dp"
                android:layout_marginTop="10dp"
                android:scaleType="fitXY"
                android:src="@drawable/stairs"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/boys_restroom"
                android:layout_width="86dp"
                android:layout_height="28dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_room_outline_gray"
                android:gravity="center"
                android:text="Boy's Restroom"
                android:textColor="@color/floor_room_label"
                android:textSize="9sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/girls_restroom"
                android:layout_width="64dp"
                android:layout_height="30dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_room_outline_gray"
                android:gravity="center"
                android:text="Girl's&#10;Restroom"
                android:textColor="@color/floor_room_label"
                android:textSize="9sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/boys_restroom" />

            <include
                android:id="@+id/room_left_1"
                layout="@layout/item_floor_room_left"
                android:layout_width="96dp"
                android:layout_height="170dp"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/stairs_top" />

            <include
                android:id="@+id/room_right_1"
                layout="@layout/item_floor_room_right"
                android:layout_width="96dp"
                android:layout_height="58dp"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/girls_restroom" />

            <include
                android:id="@+id/room_left_2"
                layout="@layout/item_floor_room_left"
                android:layout_width="96dp"
                android:layout_height="138dp"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/room_left_1" />

            <include
                android:id="@+id/room_right_2"
                layout="@layout/item_floor_room_right"
                android:layout_width="96dp"
                android:layout_height="157dp"
                android:layout_marginTop="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/room_right_1" />

            <include
                android:id="@+id/room_left_3"
                layout="@layout/item_floor_room_left"
                android:layout_width="96dp"
                android:layout_height="88dp"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/room_left_2" />

            <include
                android:id="@+id/room_right_3"
                layout="@layout/item_floor_room_right"
                android:layout_width="96dp"
                android:layout_height="134dp"
                android:layout_marginTop="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/room_right_2" />

            <include
                android:id="@+id/room_left_4"
                layout="@layout/item_floor_room_left"
                android:layout_width="96dp"
                android:layout_height="136dp"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/room_left_3" />

            <include
                android:id="@+id/room_right_4"
                layout="@layout/item_floor_room_right"
                android:layout_width="96dp"
                android:layout_height="76dp"
                android:layout_marginTop="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/room_right_3" />

            <include
                android:id="@+id/room_left_5"
                layout="@layout/item_floor_room_left"
                android:layout_width="96dp"
                android:layout_height="138dp"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/room_left_4" />

            <include
                android:id="@+id/room_right_5"
                layout="@layout/item_floor_room_right"
                android:layout_width="96dp"
                android:layout_height="76dp"
                android:layout_marginTop="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/room_right_4" />

            <include
                android:id="@+id/room_left_6"
                layout="@layout/item_floor_room_left"
                android:layout_width="96dp"
                android:layout_height="68dp"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/room_left_5" />

            <include
                android:id="@+id/room_right_6"
                layout="@layout/item_floor_room_right"
                android:layout_width="96dp"
                android:layout_height="76dp"
                android:layout_marginTop="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/room_right_5" />

            <include
                android:id="@+id/room_left_7"
                layout="@layout/item_floor_room_left"
                android:layout_width="96dp"
                android:layout_height="84dp"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/room_left_6" />

            <include
                android:id="@+id/room_right_7"
                layout="@layout/item_floor_room_right"
                android:layout_width="96dp"
                android:layout_height="76dp"
                android:layout_marginTop="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/room_right_6" />

            <include
                android:id="@+id/room_right_8"
                layout="@layout/item_floor_room_right"
                android:layout_width="96dp"
                android:layout_height="136dp"
                android:layout_marginTop="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/room_right_7" />

            <ImageView
                android:id="@+id/stairs_bottom"
                android:layout_width="94dp"
                android:layout_height="34dp"
                android:layout_marginTop="12dp"
                android:scaleType="fitXY"
                android:src="@drawable/stairs"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/room_left_7" />

            <TextView
                android:id="@+id/elevator"
                android:layout_width="66dp"
                android:layout_height="34dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_room_outline_gray"
                android:gravity="center"
                android:text="Elevator"
                android:textColor="@color/floor_room_label"
                android:textSize="9sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/room_right_8" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</LinearLayout>
