<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_default"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_horizontal_gutter"
        android:paddingTop="20dp"
        android:paddingEnd="@dimen/screen_horizontal_gutter"
        android:paddingBottom="36dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_admin_dashboard_welcome"
                    style="@style/Style.FreshGuide.Text.AdminWelcome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Welcome," />

                <TextView
                    android:id="@+id/tv_admin_dashboard_name"
                    style="@style/Style.FreshGuide.Text.AdminName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-6dp"
                    android:text="Admin" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_admin_logout"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_logout"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_logout"
                app:tint="@color/text_hint" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_admin_dashboard_date"
            style="@style/Style.FreshGuide.Text.AdminPageSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:fontFamily="@font/inter_bold"
            android:text="Monday, February 26" />

        <TextView
            style="@style/Style.FreshGuide.Text.AdminSectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="@string/admin_section_overview" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_rooms_overview"
                style="@style/Style.FreshGuide.Card.AdminOverviewTile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/admin_summary_rooms_image"
                        android:scaleType="fitCenter"
                        android:src="@drawable/total_rooms" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:layout_marginStart="18dp"
                        android:layout_marginTop="18dp"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Style.FreshGuide.Text.AdminSummaryLabelTop"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total" />

                        <TextView
                            style="@style/Style.FreshGuide.Text.AdminSummaryLabelBottom"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rooms" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_room_count"
                        style="@style/Style.FreshGuide.Text.AdminSummaryNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_marginStart="18dp"
                        android:layout_marginBottom="16dp"
                        android:text="0" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_buildings_overview"
                style="@style/Style.FreshGuide.Card.AdminOverviewTile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/admin_summary_buildings_image"
                        android:scaleType="fitCenter"
                        android:src="@drawable/total_buildings" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:layout_marginStart="18dp"
                        android:layout_marginTop="18dp"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Style.FreshGuide.Text.AdminSummaryLabelTop"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total" />

                        <TextView
                            style="@style/Style.FreshGuide.Text.AdminSummaryLabelBottom"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Buildings" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_building_count"
                        style="@style/Style.FreshGuide.Text.AdminSummaryNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_marginStart="18dp"
                        android:layout_marginBottom="16dp"
                        android:text="0" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_floors_overview"
                style="@style/Style.FreshGuide.Card.AdminOverviewTile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/admin_summary_floors_image"
                        android:scaleType="fitCenter"
                        android:src="@drawable/total_floors" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:layout_marginStart="18dp"
                        android:layout_marginTop="18dp"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Style.FreshGuide.Text.AdminSummaryLabelTop"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total" />

                        <TextView
                            style="@style/Style.FreshGuide.Text.AdminSummaryLabelBottom"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Floors" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_floor_count"
                        style="@style/Style.FreshGuide.Text.AdminSummaryNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_marginStart="18dp"
                        android:layout_marginBottom="16dp"
                        android:text="0" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_routes_overview"
                style="@style/Style.FreshGuide.Card.AdminOverviewTile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/admin_summary_routes_image"
                        android:scaleType="fitCenter"
                        android:src="@drawable/total_routes" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:layout_marginStart="18dp"
                        android:layout_marginTop="18dp"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Style.FreshGuide.Text.AdminSummaryLabelTop"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total" />

                        <TextView
                            style="@style/Style.FreshGuide.Text.AdminSummaryLabelBottom"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Routes" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_route_count"
                        style="@style/Style.FreshGuide.Text.AdminSummaryNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_marginStart="18dp"
                        android:layout_marginBottom="16dp"
                        android:text="0" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <TextView
            style="@style/Style.FreshGuide.Text.AdminSectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/admin_section_management" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Style.FreshGuide.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp"
                android:paddingBottom="18dp">

                <TextView
                    style="@style/Style.FreshGuide.Text.CardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Campus Structure"
                    android:textSize="17sp" />

                <TextView
                    style="@style/Style.FreshGuide.Text.CardBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Main buildings, floors, rooms, and mapped campus areas without drifting from the student experience."
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_manage_buildings"
                        style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_admin_dashboard_action"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="BUILDINGS" />

                    <TextView
                        android:id="@+id/btn_manage_floors"
                        style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_admin_dashboard_action"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="FLOORS" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_manage_rooms"
                        style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_admin_dashboard_action"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="ROOMS" />

                    <TextView
                        android:id="@+id/btn_manage_campus_areas"
                        style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_admin_dashboard_action"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="CAMPUS AREA" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Style.FreshGuide.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp"
                android:paddingBottom="18dp">

                <TextView
                    style="@style/Style.FreshGuide.Text.CardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Navigation Data"
                    android:textSize="17sp" />

                <TextView
                    style="@style/Style.FreshGuide.Text.CardBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Facilities, origins, and routes that extend the current student directions experience."
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_manage_facilities"
                        style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_admin_dashboard_action"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="FACILITIES" />

                    <TextView
                        android:id="@+id/btn_manage_origins"
                        style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_admin_dashboard_action"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="ORIGINS" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_manage_routes"
                    style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_admin_dashboard_action"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="ROUTES" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Style.FreshGuide.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp"
                android:paddingBottom="18dp">

                <TextView
                    style="@style/Style.FreshGuide.Text.CardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Release Pipeline"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/tv_admin_sync_version"
                    style="@style/Style.FreshGuide.Text.CardBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Current data version: Not synced"
                    android:textSize="13sp" />

                <TextView
                    style="@style/Style.FreshGuide.Text.CardBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Publish the latest local data so students can sync a consistent, up-to-date campus guide."
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/btn_publish"
                    style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_admin_dashboard_action"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="PUBLISH TO STUDENTS" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
