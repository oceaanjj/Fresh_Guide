<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_default"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_horizontal_gutter"
        android:paddingTop="20dp"
        android:paddingEnd="@dimen/screen_horizontal_gutter"
        android:paddingBottom="36dp">

        <TextView
            android:id="@+id/tv_admin_dashboard_title"
            style="@style/Style.FreshGuide.Text.AdminPageTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Welcome, Admin" />

        <TextView
            android:id="@+id/tv_admin_dashboard_date"
            style="@style/Style.FreshGuide.Text.AdminPageSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Monday, February 26" />

        <TextView
            style="@style/Style.FreshGuide.Text.AdminSectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="@string/admin_section_overview" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rooms_overview"
            style="@style/Style.FreshGuide.Card.AdminSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="80dp"
                android:orientation="horizontal"
                android:paddingStart="28dp"
                android:paddingTop="14dp"
                android:paddingEnd="40dp"
                android:paddingBottom="14dp">

                <TextView
                    android:id="@+id/tv_room_count"
                    style="@style/Style.FreshGuide.Text.AdminSummaryNumber"
                    android:layout_width="62dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="0" />

                <TextView
                    style="@style/Style.FreshGuide.Text.AdminSummaryLabel"
                    android:layout_width="162dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="Total&#10;Rooms" />

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:contentDescription="@string/admin_summary_rooms_image"
                    android:scaleType="fitCenter"
                    android:src="@drawable/total_rooms" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_buildings_overview"
            style="@style/Style.FreshGuide.Card.AdminSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="80dp"
                android:orientation="horizontal"
                android:paddingStart="28dp"
                android:paddingTop="14dp"
                android:paddingEnd="40dp"
                android:paddingBottom="14dp">

                <TextView
                    android:id="@+id/tv_building_count"
                    style="@style/Style.FreshGuide.Text.AdminSummaryNumber"
                    android:layout_width="52dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="0" />

                <TextView
                    style="@style/Style.FreshGuide.Text.AdminSummaryLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="Total&#10;Buildings"/>

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:contentDescription="@string/admin_summary_buildings_image"
                    android:scaleType="fitCenter"
                    android:src="@drawable/total_buildings" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_floors_overview"
            style="@style/Style.FreshGuide.Card.AdminSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="80dp"
                android:orientation="horizontal"
                android:paddingStart="28dp"
                android:paddingTop="14dp"
                android:paddingEnd="40dp"
                android:paddingBottom="14dp">

                <TextView
                    android:id="@+id/tv_floor_count"
                    style="@style/Style.FreshGuide.Text.AdminSummaryNumber"
                    android:layout_width="52dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="0" />

                <TextView
                    style="@style/Style.FreshGuide.Text.AdminSummaryLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="Total&#10;Floors" />

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:contentDescription="@string/admin_summary_floors_image"
                    android:scaleType="fitCenter"
                    android:src="@drawable/total_floors" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_routes_overview"
            style="@style/Style.FreshGuide.Card.AdminSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="80dp"
                android:orientation="horizontal"
                android:paddingStart="28dp"
                android:paddingTop="14dp"
                android:paddingEnd="40dp"
                android:paddingBottom="14dp">

                <TextView
                    android:id="@+id/tv_route_count"
                    style="@style/Style.FreshGuide.Text.AdminSummaryNumber"
                    android:layout_width="52dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="0" />

                <TextView
                    style="@style/Style.FreshGuide.Text.AdminSummaryLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="Total&#10;Routes" />

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:contentDescription="@string/admin_summary_routes_image"
                    android:scaleType="fitCenter"
                    android:src="@drawable/total_routes" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/Style.FreshGuide.Text.AdminSectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/admin_section_management" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Style.FreshGuide.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp"
                android:paddingBottom="18dp">

                <TextView
                    style="@style/Style.FreshGuide.Text.CardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Campus Structure"
                    android:textSize="17sp" />

                <TextView
                    style="@style/Style.FreshGuide.Text.CardBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Main buildings, floors, rooms, and mapped campus areas without drifting from the student experience."
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_manage_buildings"
                        style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_admin_dashboard_action"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="BUILDINGS" />

                    <TextView
                        android:id="@+id/btn_manage_floors"
                        style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_admin_dashboard_action"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="FLOORS" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_manage_rooms"
                        style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_admin_dashboard_action"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="ROOMS" />

                    <TextView
                        android:id="@+id/btn_manage_campus_areas"
                        style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_admin_dashboard_action"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="CAMPUS AREA" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Style.FreshGuide.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp"
                android:paddingBottom="18dp">

                <TextView
                    style="@style/Style.FreshGuide.Text.CardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Navigation Data"
                    android:textSize="17sp" />

                <TextView
                    style="@style/Style.FreshGuide.Text.CardBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Facilities, origins, and routes that extend the current student directions experience."
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_manage_facilities"
                        style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_admin_dashboard_action"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="FACILITIES" />

                    <TextView
                        android:id="@+id/btn_manage_origins"
                        style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_admin_dashboard_action"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="ORIGINS" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_manage_routes"
                    style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_admin_dashboard_action"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="ROUTES" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Style.FreshGuide.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp"
                android:paddingBottom="18dp">

                <TextView
                    style="@style/Style.FreshGuide.Text.CardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Release Pipeline"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/tv_admin_sync_version"
                    style="@style/Style.FreshGuide.Text.CardBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Current data version: Not synced"
                    android:textSize="13sp" />

                <TextView
                    style="@style/Style.FreshGuide.Text.CardBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Publish the latest local data so students can sync a consistent, up-to-date campus guide."
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/btn_publish"
                    style="@style/Style.FreshGuide.Text.AdminDashboardAction"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_admin_dashboard_action"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="PUBLISH TO STUDENTS" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
