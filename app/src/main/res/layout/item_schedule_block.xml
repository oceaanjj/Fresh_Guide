<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_schedule_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/inter_medium"
            android:text="Schedule 1"
            android:textColor="@color/schedule_form_label"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_delete_schedule"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="Delete schedule block"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="#FF3B30"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/day_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:weightSum="6" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_start"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_field_pill"
            android:drawableStart="@android:drawable/ic_lock_idle_alarm"
            android:drawablePadding="6dp"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:text="Start Time"
            android:textColor="@color/schedule_time_placeholder"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_end"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_field_pill"
            android:drawableStart="@android:drawable/ic_lock_idle_alarm"
            android:drawablePadding="6dp"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:text="End Time"
            android:textColor="@color/schedule_time_placeholder"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>