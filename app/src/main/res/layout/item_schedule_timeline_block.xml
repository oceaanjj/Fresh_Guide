<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="7dp"
    android:paddingEnd="8dp"
    android:paddingBottom="7dp"
    android:clipChildren="true"
    android:clipToPadding="true">

    <!-- Start time label at top -->
    <TextView
        android:id="@+id/tv_block_start_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="9sp"
        android:includeFontPadding="false"
        android:letterSpacing="0.02" />

    <!-- Subject title — main visual anchor -->
    <TextView
        android:id="@+id/tv_block_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textSize="13sp"
        android:textStyle="bold"
        android:includeFontPadding="false"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Subject code — secondary -->
    <TextView
        android:id="@+id/tv_block_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:textSize="10sp"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Spacer pushes end time and location to bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Location (room or platform) -->
    <TextView
        android:id="@+id/tv_block_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="9sp"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- End time label at bottom -->
    <TextView
        android:id="@+id/tv_block_end_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:textSize="9sp"
        android:includeFontPadding="false" />

</LinearLayout>