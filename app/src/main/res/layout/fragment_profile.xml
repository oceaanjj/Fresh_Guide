<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_default"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="110dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/screen_horizontal_gutter"
        android:paddingTop="4dp"
        android:paddingEnd="@dimen/screen_horizontal_gutter"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/tv_profile_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/inter_extrabold"
            android:paddingLeft="15dp"
            android:paddingRight="10dp"
            android:text="@string/profile_title"
            android:textColor="@color/green_primary"
            android:textSize="32sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_profile_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_bold"
            android:paddingLeft="14dp"
            android:text="Monday, February 26"
            android:textColor="@color/text_hint"
            android:textSize="15sp"
            app:layout_constraintStart_toStartOf="@id/tv_profile_title"
            app:layout_constraintTop_toBottomOf="@id/tv_profile_title" />

        <ImageButton
            android:id="@+id/btn_more"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="20dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/profile_more"
            android:padding="8dp"
            android:src="@drawable/ic_more_vert"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/green_primary" />

        <ImageButton
            android:id="@+id/btn_edit_profile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/profile_edit"
            android:padding="8dp"
            android:src="@drawable/ic_edit"
            app:layout_constraintEnd_toStartOf="@id/btn_more"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/green_primary" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_student_id"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="30dp"
            android:layout_marginEnd="12dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="16dp"
            app:cardElevation="5dp"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false"
            app:layout_constraintDimensionRatio="350:540"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_profile_date"
            app:strokeColor="@android:color/transparent"
            app:strokeWidth="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                >

                <ImageView
                    android:id="@+id/img_student_id_bg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/profile_student_id_background"
                    android:scaleType="fitXY"
                    android:src="@drawable/student_id" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="top|center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingTop="130dp"
                    android:paddingEnd="24dp"
                    android:paddingBottom="24dp">

                    <FrameLayout
                        android:id="@+id/profile_photo_container"
                        android:layout_width="150dp"
                        android:layout_height="150dp">

                        <ImageView
                            android:id="@+id/img_profile_photo"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_profile_photo"
                            android:contentDescription="@string/profile_photo"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_profile_initial"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_profile_initial"
                            android:gravity="center"
                            android:text="T"
                            android:textColor="@android:color/white"
                            android:textSize="52sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tv_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="TEST STUDENT"
                        android:textAlignment="center"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_course_section"
                        android:layout_width="250dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:background="@drawable/bg_course_pill"
                        android:gravity="center"
                        android:paddingStart="18dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="10dp"
                        android:text="BSCS 3A"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_student_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="20231315-S"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_saved_locations_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/inter_bold"
            android:text="@string/profile_saved_title"
            android:textColor="@color/green_primary"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="@id/card_student_id"
            app:layout_constraintStart_toStartOf="@id/card_student_id"
            app:layout_constraintTop_toBottomOf="@id/card_student_id" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_saved_locations"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="24dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/card_student_id"
            app:layout_constraintStart_toStartOf="@id/card_student_id"
            app:layout_constraintTop_toBottomOf="@id/tv_saved_locations_title"
            tools:itemCount="4"
            tools:listitem="@layout/item_favorite_room" />

        <LinearLayout
            android:id="@+id/layout_saved_locations_empty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="56dp"
            android:paddingEnd="18dp"
            android:paddingBottom="56dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/card_student_id"
            app:layout_constraintStart_toStartOf="@id/card_student_id"
            app:layout_constraintTop_toBottomOf="@id/tv_saved_locations_title">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_star_outline"
                app:tint="@color/border_default" />

            <TextView
                android:id="@+id/tv_saved_locations_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="@string/profile_saved_empty"
                android:textColor="@color/text_hint"
                android:textSize="14sp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
