<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/et_room_name"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_search_bar"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:hint="Room Name"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <EditText
            android:id="@+id/et_room_code"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_search_bar"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:hint="Room Code (e.g. RM-201)"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <EditText
            android:id="@+id/et_room_type"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_search_bar"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:hint="Type (Classroom / Lab / Office)"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <EditText
            android:id="@+id/et_floor_id"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_search_bar"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:hint="Floor ID"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:inputType="number" />

        <EditText
            android:id="@+id/et_room_description"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_search_bar"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:hint="Description"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:inputType="textMultiLine"
            android:gravity="top" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save Room"
            android:backgroundTint="@color/green_primary"
            android:textColor="@color/surface_white"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
