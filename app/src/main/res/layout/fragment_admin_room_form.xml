<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sheet_top_radius"
    android:orientation="vertical">

    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <TextView
        android:id="@+id/tv_admin_room_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/inter_medium"
        android:gravity="center"
        android:text="@string/admin_room_form_title"
        android:textColor="@color/schedule_form_label"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_admin_room_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/inter_regular"
        android:gravity="center"
        android:text="@string/admin_room_form_subtitle"
        android:textColor="@color/text_hint"
        android:textSize="12sp"
        android:visibility="gone" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_horizontal_gutter"
            android:paddingTop="14dp"
            android:paddingEnd="@dimen/screen_horizontal_gutter"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:text="Room Name"
                android:textColor="@color/schedule_form_label"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_room_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_field_pill"
                android:fontFamily="@font/inter_medium"
                android:hint="Enter room name"
                android:inputType="textCapWords"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/inter_regular"
                android:text="Room Code"
                android:textColor="@color/schedule_form_label"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_room_code"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_field_pill"
                android:fontFamily="@font/inter_medium"
                android:hint="Enter room code"
                android:inputType="textCapCharacters"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/inter_regular"
                android:text="Room Type"
                android:textColor="@color/schedule_form_label"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_room_type"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_field_pill"
                android:fontFamily="@font/inter_medium"
                android:hint="Choose room type"
                android:inputType="textCapWords"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/inter_regular"
                android:text="Floor ID"
                android:textColor="@color/schedule_form_label"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_floor_id"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_field_pill"
                android:fontFamily="@font/inter_medium"
                android:hint="Enter Floor ID"
                android:inputType="number"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/inter_regular"
                android:text="Description"
                android:textColor="@color/schedule_form_label"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_room_description"
                android:layout_width="match_parent"
                android:layout_height="112dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_field_pill"
                android:fontFamily="@font/inter_medium"
                android:gravity="top|start"
                android:hint="Enter description"
                android:inputType="textMultiLine|textCapSentences"
                android:minHeight="112dp"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/inter_regular"
                android:text="Room Image"
                android:textColor="@color/schedule_form_label"
                android:textSize="14sp"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="144dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_admin_room_upload"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/iv_room_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Room image preview"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_image_placeholder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:drawableTop="@drawable/ic_upload_cloud"
                    android:gravity="center"
                    android:text="Upload image"
                    android:textAlignment="center"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_select_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:contentDescription="Select room image"
                    android:text="" />

                <Button
                    android:id="@+id/btn_remove_image"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="10dp"
                    android:background="@drawable/bg_admin_icon_button_danger"
                    android:fontFamily="@font/inter_bold"
                    android:text="x"
                    android:textAllCaps="false"
                    android:textColor="@color/red_accent"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_card"
        android:orientation="vertical"
        android:paddingStart="30dp"
        android:paddingTop="10dp"
        android:paddingEnd="30dp"
        android:paddingBottom="16dp">

        <Button
            android:id="@+id/btn_save"
            style="@style/Style.FreshGuide.Button.Admin.BottomSheetPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save" />
    </LinearLayout>
</LinearLayout>
