<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet_surface"
    android:orientation="vertical">

    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_horizontal_gutter"
            android:paddingTop="18dp"
            android:paddingEnd="@dimen/screen_horizontal_gutter"
            android:paddingBottom="28dp">

            <TextView
                android:id="@+id/tv_admin_room_title"
                style="@style/Style.FreshGuide.Text.AdminBottomSheetTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/admin_room_form_title" />

            <TextView
                android:id="@+id/tv_admin_room_subtitle"
                style="@style/Style.FreshGuide.Text.AdminPageSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/admin_room_form_subtitle" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Style.FreshGuide.Card.Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="18dp">

                    <TextView
                        style="@style/Style.FreshGuide.Text.FieldLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Room Name" />

                    <EditText
                        android:id="@+id/et_room_name"
                        style="@style/Style.FreshGuide.Input.Field"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Room Name" />

                    <TextView
                        style="@style/Style.FreshGuide.Text.FieldLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Room Code" />

                    <EditText
                        android:id="@+id/et_room_code"
                        style="@style/Style.FreshGuide.Input.Field"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Room Code (e.g. RM-201)" />

                    <TextView
                        style="@style/Style.FreshGuide.Text.FieldLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Room Type" />

                    <EditText
                        android:id="@+id/et_room_type"
                        style="@style/Style.FreshGuide.Input.Field"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Type (Classroom / Lab / Office)" />

                    <TextView
                        style="@style/Style.FreshGuide.Text.FieldLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Floor ID" />

                    <EditText
                        android:id="@+id/et_floor_id"
                        style="@style/Style.FreshGuide.Input.Field"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Floor ID"
                        android:inputType="number" />

                    <TextView
                        style="@style/Style.FreshGuide.Text.FieldLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Description" />

                    <EditText
                        android:id="@+id/et_room_description"
                        style="@style/Style.FreshGuide.Input.Field"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="top|start"
                        android:hint="Description"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minHeight="104dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Style.FreshGuide.Card.Highlight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="18dp">

                    <TextView
                        style="@style/Style.FreshGuide.Text.CardTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Room Image" />

                    <TextView
                        style="@style/Style.FreshGuide.Text.CardBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Use a landscape image so the preview matches student-facing room cards and detail sheets." />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_input_field">

                        <ImageView
                            android:id="@+id/iv_room_preview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="Room image preview"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_image_placeholder"
                            style="@style/Style.FreshGuide.Text.CardBody"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text="No image selected&#10;Tap below to add a landscape image"
                            android:textAlignment="center" />

                    <Button
                        android:id="@+id/btn_remove_image"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="8dp"
                        android:background="@drawable/bg_admin_icon_button_danger"
                        android:fontFamily="@font/inter_bold"
                        android:text="x"
                        android:textAllCaps="false"
                        android:textColor="@color/red_accent"
                        android:visibility="gone" />
                    </FrameLayout>

                    <Button
                        android:id="@+id/btn_select_image"
                        style="@style/Style.FreshGuide.Button.Admin"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="12dp"
                        android:text="Select Landscape Image" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/btn_save"
                style="@style/Style.FreshGuide.Button.Admin.Primary"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="18dp"
                android:text="Save Room"
                android:textSize="14sp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
