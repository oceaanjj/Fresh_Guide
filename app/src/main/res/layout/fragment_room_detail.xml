<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@drawable/bg_room_detail_sheet"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="12dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_bottom_sheet_handle" />

        <LinearLayout
            android:id="@+id/layout_room_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_room_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_medium"
                    android:textColor="@color/room_detail_heading"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_room_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/inter_medium"
                    android:textColor="@color/room_detail_subtitle"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_room_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_chip_green"
                    android:fontFamily="@font/inter_medium"
                    android:paddingStart="8dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="3dp"
                    android:textColor="@color/surface_white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_room_bookmark"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Bookmark"
                android:padding="8dp"
                android:src="@drawable/ic_bookmark_outline"
                app:tint="@color/green_primary" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_get_directions"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/inter_medium"
            android:text="DIRECTIONS"
            android:textAllCaps="false"
            android:textColor="@color/green_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/room_detail_directions_bg"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_directions"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="@color/green_primary"
            app:strokeColor="@color/green_primary"
            app:strokeWidth="1dp" />

        <FrameLayout
            android:id="@+id/image_card"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="20dp">

            <FrameLayout
                android:id="@+id/single_image_card"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_room_media_placeholder"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/iv_room_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Room image"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/tv_image_placeholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/inter_regular"
                    android:gravity="center"
                    android:text="No room image"
                    android:textColor="@color/room_detail_placeholder"
                    android:textSize="14sp" />
            </FrameLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_room_gallery"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:visibility="gone" />

            <View
                android:id="@+id/gallery_fade_left"
                android:layout_width="24dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_fade_left"
                android:visibility="gone" />

            <View
                android:id="@+id/gallery_fade_right"
                android:layout_width="24dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:background="@drawable/bg_fade_right"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/inter_medium"
            android:text="Description"
            android:textColor="@color/room_detail_heading"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_room_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/inter_regular"
            android:textColor="@color/room_detail_body"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/inter_medium"
            android:text="Facilities"
            android:textColor="@color/room_detail_section_label"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_facilities"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/inter_regular"
            android:textColor="@color/room_detail_facilities_text"
            android:textSize="14sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
