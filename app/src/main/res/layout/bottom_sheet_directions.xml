<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sheet_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet_surface"
    android:clickable="true"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:focusable="true"
    android:paddingStart="20dp"
    android:paddingTop="12dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp">

    <View
        android:id="@+id/view_sheet_handle"
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:background="@drawable/bg_bottom_sheet_handle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="@font/inter_medium"
        android:gravity="center"
        android:text="@string/label_direction"
        android:textColor="@color/green_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_sheet_handle" />

    <TextView
        android:id="@+id/tv_origin_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="34dp"
        android:fontFamily="@font/inter_medium"
        android:text="@string/label_origin"
        android:textColor="@color/green_primary"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <LinearLayout
        android:id="@+id/layout_origin_field"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:layout_marginStart="34dp"
        android:background="@drawable/bg_field_pill"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_origin_label">

        <EditText
            android:id="@+id/et_origin_search"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:fontFamily="@font/inter_medium"
            android:hint="@string/hint_choose_origin"
            android:imeOptions="actionNext"
            android:inputType="textCapWords"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/btn_clear_origin"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@null"
            android:padding="6dp"
            android:src="@drawable/ic_search_close"
            android:tint="@color/text_hint"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_destination_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginStart="34dp"
        android:fontFamily="@font/inter_medium"
        android:text="@string/label_destination"
        android:textColor="@color/green_primary"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_origin_field" />

    <LinearLayout
        android:id="@+id/layout_destination_field"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:layout_marginStart="34dp"
        android:background="@drawable/bg_field_pill"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_destination_label">

        <EditText
            android:id="@+id/et_destination_search"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:fontFamily="@font/inter_medium"
            android:hint="@string/hint_choose_destination"
            android:imeOptions="actionDone"
            android:inputType="textCapWords"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/btn_clear_destination"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@null"
            android:padding="6dp"
            android:src="@drawable/ic_search_close"
            android:tint="@color/text_hint"
            android:visibility="gone" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_start_directions"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/inter_medium"
        android:text="@string/action_start_directions"
        android:textAllCaps="false"
        android:textColor="@color/green_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@color/green_pill"
        app:cornerRadius="25dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="@color/green_light"
        app:strokeWidth="1dp" />

    <View
        android:id="@+id/view_results_scrim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/view_origin_dot"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:background="@drawable/bg_direction_origin_dot"
        app:layout_constraintBottom_toBottomOf="@id/layout_origin_field"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/layout_origin_field" />

    <View
        android:id="@+id/view_direction_connector"
        android:layout_width="18dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_direction_connector"
        app:layout_constraintBottom_toTopOf="@id/view_destination_dot"
        app:layout_constraintStart_toStartOf="@id/view_origin_dot"
        app:layout_constraintEnd_toEndOf="@id/view_origin_dot"
        app:layout_constraintTop_toBottomOf="@id/view_origin_dot" />

    <View
        android:id="@+id/view_destination_dot"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:background="@drawable/bg_direction_destination_dot"
        app:layout_constraintBottom_toBottomOf="@id/layout_destination_field"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/layout_destination_field" />

    <LinearLayout
        android:id="@+id/layout_origin_results"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_room_item"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/layout_origin_field"
        app:layout_constraintStart_toStartOf="@id/layout_origin_field"
        app:layout_constraintTop_toBottomOf="@id/layout_origin_field">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_origin_results"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false" />

        <TextView
            android:id="@+id/tv_origin_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fontFamily="@font/inter_regular"
            android:gravity="center"
            android:text="@string/label_no_origins"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_destination_results"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_room_item"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/layout_destination_field"
        app:layout_constraintStart_toStartOf="@id/layout_destination_field"
        app:layout_constraintTop_toBottomOf="@id/layout_destination_field">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_destination_results"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false" />

        <TextView
            android:id="@+id/tv_destination_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fontFamily="@font/inter_regular"
            android:gravity="center"
            android:text="@string/label_no_rooms"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
