<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/neutral_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/neutral_stroke" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/red_pressed" />
            <stroke
                android:width="1dp"
                android:color="@color/red_accent" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/red_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/red_accent" />
            <corners android:radius="20dp" />
        </shape>
    </item>

</selector>
