<?xml version="1.0" encoding="utf-8"?>

<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 0: Base semi-transparent glass fill -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_card_fill" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- Layer 1: Top-to-bottom highlight gradient — the "reflection" -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/glass_highlight_top"
                android:endColor="@color/glass_highlight_bottom" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- Layer 2: Outer rim — hairline white border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_card_stroke" />
            <corners android:radius="28dp" />
        </shape>
    </item>

</layer-list>