<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/stairs_indicator_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/stairs_indicator_stroke" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/stairs_indicator_overlay" />
            <corners android:radius="19dp" />
        </shape>
    </item>

    <item
        android:left="12dp"
        android:top="3dp"
        android:right="12dp"
        android:bottom="19dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/stairs_indicator_highlight"
                android:endColor="#00FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
