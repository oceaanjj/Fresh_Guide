<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0033AA22"
                android:centerColor="#8833AA22"
                android:endColor="#0033AA22"
                android:angle="270"
                android:centerY="0.5" />
            <corners android:radius="4dp" />
        </shape>
    </item>

    <!-- Core bright line -->
    <item
        android:top="6dp"
        android:bottom="6dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0066CC44"
                android:centerColor="#FF66CC44"
                android:endColor="#0066CC44"
                android:angle="0" />
            <corners android:radius="2dp" />
        </shape>
    </item>

</layer-list>