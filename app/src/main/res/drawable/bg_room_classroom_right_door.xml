<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/classroom_fill" />
            <stroke
                android:width="1dp"
                android:color="@color/classroom_stroke" />
        </shape>
    </item>

    <item
        android:width="5dp"
        android:height="12dp"
        android:gravity="top|end">
        <shape android:shape="rectangle">
            <solid android:color="@color/classroom_stroke" />
        </shape>
    </item>

    <item
        android:width="5dp"
        android:height="12dp"
        android:gravity="bottom|end">
        <shape android:shape="rectangle">
            <solid android:color="@color/classroom_stroke" />
        </shape>
    </item>

</layer-list>